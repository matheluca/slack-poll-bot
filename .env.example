# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# Usuários autorizados a criar enquetes (IDs separados por vírgula)
AUTHORIZED_USERS=U000000000,U000000001

# Canal de teste (sempre incluído nos envios)
CHANNEL_TEST=C000000000

# Canais disponíveis para seleção (JSON array)
# Formato: [{"label":"Nome","id":"CXXXXXXX"},...]
CHANNEL_OPTIONS=[{"label":"C1 - Connect","id":"C000000000"},{"label":"Geral","id":"C000000001"},{"label":"Teste","id":"C000000002"}]

# Canais do grupo "mix" (IDs separados por vírgula)
MIX_CHANNELS=C000000000,C000000001,C000000002

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# Enquete agendada (send-poll)
SEND_POLL_CHANNELS=C000000000,C000000001
SEND_POLL_QUESTION=Você já atualizou as OPs do seu funil para evitar irregularidade?
SEND_POLL_OPTIONS=😄 Sim!;😐 Ainda não!;😞 Ed, estava esquecendo. Obrigado!
